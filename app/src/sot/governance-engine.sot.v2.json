{
  "schemaVersion": "2.0.0",
  "id": "governance-engine",
  "kernelModule": "app/src/kernel/GovernanceEngine.js",
  "runtimeEntry": "dev/tools/runtime/run-required-checks.mjs",
  "policy": "kernel-governance-engine.v2",
  "runModes": [
    "verify-first",
    "sync-and-verify"
  ],
  "pipeline": {
    "sync": [
      "versioning:sync",
      "governance:llm:sync",
      "governance:subagent:sync",
      "docs:v2:sync",
      "test:sync",
      "repo:hygiene:sync"
    ],
    "verify": [
      "llm:guard",
      "versioning:verify",
      "governance:policy:verify",
      "governance:modularity:verify",
      "governance:llm:verify",
      "governance:subagent:verify",
      "test:verify",
      "evidence:verify",
      "testline:verify",
      "repo:hygiene:verify",
      "docs:v2:verify",
      "docs:v2:coverage",
      "docs:tasks:verify",
      "governance:coverage:verify"
    ],
    "post_verify": [
      "governance:findings:materialize",
      "governance:findings:verify"
    ],
    "contract": "verify-first is the default required mode and stays write-free; sync/materialize only run in explicit sync-and-verify mode, llm:guard is the mandatory read/commit/push gate, verify steps are always mandatory and fail-closed; post_verify runs only in sync-and-verify mode"
  },
  "proofArtifacts": [
    "runtime/evidence/required-check-report.json",
    "runtime/evidence/governance-findings.json",
    "runtime/evidence/governance-proof-manifest.json",
    "runtime/evidence/governance-coverage.json",
    "runtime/evidence/governance-modularity.json",
    "VERSION",
    "runtime/evidence/summary.json",
    "runtime/evidence/final/testline-summary.json"
  ],
  "kernelIntegration": {
    "controller": "app/src/kernel/KernelController.js",
    "gateManager": "app/src/kernel/GateManager.js",
    "engineResponsibilities": [
      "single source for pipeline contract",
      "single source for claim rule",
      "single source for governance report schema",
      "single source for kernel deny/audit behavior",
      "single source for zero-trust proof manifest contract"
    ]
  },
  "docsIntegration": {
    "docsV2Sot": "app/src/sot/docs-v2.json",
    "truthDocs": [
      "docs/SOT/ORIENTATION.md",
      "docs/MANUEL/WORKFLOW.md",
      "docs/LLM/ENTRY.md",
      "docs/LLM/POLICY.md"
    ]
  }
}
