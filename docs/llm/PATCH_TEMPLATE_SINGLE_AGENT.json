{
  "meta": {
    "version": "0.0.1",
    "description": "Single-Agent Patch fuer SeedWorld",
    "author": "agent-name",
    "createdAt": "2026-03-27T00:00:00Z",
    "llm": {
      "agentId": "agent-001",
      "terminalExclusive": true,
      "scope": "gameplay-ui-ux"
    },
    "gates": {
      "deadmanSeconds": 600,
      "runPreflightBefore": true,
      "runPreflightAfter": true,
      "beforeCommands": [
        "npm run llm:check -- --paths src/main.js"
      ],
      "afterCommands": [
        "npm run llm:check -- --paths src/main.js"
      ],
      "allowedFilePrefixes": [
        "src/",
        "docs/",
        "tests/",
        "tools/",
        "README.md",
        "package.json",
        "index.html",
        "game.html",
        "patchUI.html",
        "patchServer.mjs",
        "patchUtils.js",
        "patches.json"
      ]
    }
  },
  "patches": [
    {
      "id": "agent-001-patch-001",
      "name": "Beispiel: String Replace",
      "type": "string-replace",
      "file": "src/main.js",
      "find": "OLD_VALUE",
      "replace": "NEW_VALUE",
      "stopOnError": true,
      "verify": {
        "type": "contains",
        "file": "src/main.js",
        "text": "NEW_VALUE"
      }
    }
  ]
}
