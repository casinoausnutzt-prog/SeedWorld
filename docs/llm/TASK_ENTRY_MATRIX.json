{
  "ui": {
    "dependsOn": [
      "gameplay",
      "contracts"
    ],
    "triggerPrefixes": [
      "src/ui/",
      "src/app/",
      "docs/llm/ui/",
      "game.html",
      "patchUI.html",
      "patchPopup.html",
      "index.html"
    ],
    "requiredEntry": "docs/llm/ui/UI_TASK_ENTRY.md"
  },
  "gameplay": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      "src/game/",
      "docs/llm/gameplay/"
    ],
    "requiredEntry": "docs/llm/gameplay/GAMEPLAY_TASK_ENTRY.md"
  },
  "contracts": {
    "dependsOn": [],
    "triggerPrefixes": [
      "src/kernel/",
      "docs/TRACEABILITY.json",
      "docs/FUNCTION_SOT.json",
      "docs/llm/contracts/"
    ],
    "requiredEntry": "docs/llm/contracts/CONTRACT_TASK_ENTRY.md"
  },
  "testing": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      "tests/",
      "tools/runtime/",
      "tools/llm-preflight.mjs",
      "docs/llm/testing/"
    ],
    "requiredEntry": "docs/llm/testing/TESTING_TASK_ENTRY.md"
  },
  "versioning": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      "package.json",
      "README.md",
      "docs/WORKFLOW.md",
      "docs/llm/",
      "docs/SCOPE.md",
      "docs/KERNEL_SPEC.md"
    ],
    "requiredEntry": "docs/llm/versioning/VERSIONING_TASK_ENTRY.md"
  }
}