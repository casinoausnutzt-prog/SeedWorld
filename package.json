{
  "name": "seedworld",
  "version": "0.3.1a",
  "private": true,
  "type": "module",
  "scripts": {
    "llm:entry": "node dev/tools/runtime/llm-entry.mjs",
    "llm:guard": "node dev/tools/runtime/llm-read-guard.mjs",
    "llm:override": "node dev/tools/runtime/llm-override.mjs",
    "sync:docs:apply": "node dev/tools/runtime/updateRedActions.mjs --write && npm run docs:v2:sync",
    "governance:llm:sync": "node dev/tools/runtime/sync-llm-read-contract.mjs --write",
    "governance:llm:verify": "node dev/tools/runtime/governance-llm-verify.mjs",
    "governance:subagent:sync": "node dev/tools/runtime/sync-sub-agent-manifest.mjs --write",
    "governance:subagent:verify": "node dev/tools/runtime/governance-subagent-verify.mjs",
    "governance:findings:materialize": "node dev/tools/runtime/governance-findings-materialize.mjs",
    "governance:findings:verify": "node dev/tools/runtime/governance-findings-verify.mjs",
    "versioning:sync": "node dev/tools/runtime/sync-versioning.mjs --write",
    "versioning:verify": "node dev/tools/runtime/sync-versioning.mjs",
    "test": "node dev/scripts/test-runner.mjs && node dev/tools/runtime/verify-docs-v2-guards.mjs",
    "test:sync": "npm test && node dev/tools/runtime/scan-doc-tasks.mjs",
    "test:verify": "npm run evidence:verify && npm run docs:v2:guard && npm run docs:tasks:verify",
    "docs:tasks:verify": "node dev/tools/runtime/scan-doc-tasks-verify.mjs",
    "evidence:verify": "node dev/scripts/verify-evidence.mjs",
    "testline:verify": "node dev/tools/runtime/verify-testline-integrity.mjs",
    "repo:hygiene:sync": "node dev/tools/runtime/repo-hygiene-map.mjs --write && node dev/tools/runtime/sync-string-matrix.mjs --write",
    "repo:hygiene:verify": "node dev/tools/runtime/repo-hygiene-verify.mjs",
    "signing:guard": "node dev/tools/runtime/signing-guard.mjs --allow-empty-range",
    "signing:guard:head": "node dev/tools/runtime/signing-guard.mjs --head-only --allow-empty-range",
    "signing:guard:head:ci": "node dev/tools/runtime/signing-guard.mjs --head-only --allow-empty-range --skip-config",
    "governance:policy:verify": "node dev/tools/runtime/governance-policy-verify.mjs",
    "governance:modularity:verify": "node dev/tools/runtime/governance-modularity-verify.mjs",
    "governance:coverage:verify": "node dev/tools/runtime/governance-coverage-verify.mjs",
    "check:required": "node dev/tools/runtime/run-required-checks.mjs",
    "check:required:verify-only": "node dev/tools/runtime/run-required-checks.mjs --verify-only",
    "check:advisory": "npm run docs:v2:coverage && npm run docs:v2:probe",
    "docs:v2:sync": "node dev/tools/runtime/sync-docs-v2.mjs --write",
    "docs:v2:verify": "node dev/tools/runtime/sync-docs-v2.mjs",
    "docs:v2:guard": "node dev/tools/runtime/verify-docs-v2-guards.mjs",
    "docs:v2:coverage": "node dev/tools/runtime/verify-docs-v2-coverage.mjs",
    "docs:v2:probe": "node dev/tools/runtime/probe-docs-v2-adversarial.mjs",
    "strings:sync": "node dev/tools/runtime/sync-string-matrix.mjs --write",
    "strings:verify": "node dev/tools/runtime/sync-string-matrix.mjs",
    "hooks:install": "node dev/tools/runtime/installGitHooks.mjs --explicit",
    "hooks:verify": "node dev/tools/runtime/verify-git-hooks.mjs"
  },
  "devDependencies": {
    "chrome-remote-interface": "^0.33.3",
    "jszip": "^3.10.1",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2"
  }
}
