{
  "name": "seedworld",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "SeedWorld - Pure Kernel-Based RTS Game (No Server Patching)",
  "scripts": {
    "start": "node patchServer.mjs",
    "kernel": "node src/mainKernel.js",
    "server": "node patchServer.mjs",
    "patch:server": "node patchServer.mjs",
    "patch:apply": "node tools/patch/apply.mjs",
    "cleanup:baseline": "node scripts/repo-cleanup-baseline.mjs --write",
    "test": "node scripts/test-runner.mjs",
    "preflight": "node scripts/test-runner.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "playwright": "^1.58.2"
  },
  "keywords": [
    "deterministic",
    "browser-game",
    "rts",
    "kernel",
    "no-patching"
  ],
  "author": "SeedWorld Team",
  "license": "MIT"
}
