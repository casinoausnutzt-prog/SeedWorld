{
  "version": "1",
  "summary": "Canonical patch kinds and operations accepted by the terminal-authority patch flow.",
  "inputContracts": [
    {
      "name": "bundle-manifest",
      "preferred": true,
      "jsonShape": "object-with-patches-array",
      "transport": [
        "zip",
        "json"
      ]
    },
    {
      "name": "single-kernel-patch",
      "preferred": false,
      "jsonShape": "single-kernel-patch-object",
      "transport": [
        "json"
      ]
    },
    {
      "name": "single-file-patch",
      "preferred": false,
      "jsonShape": "single-file-patch-object",
      "transport": [
        "json"
      ]
    }
  ],
  "patchKinds": [
    {
      "kind": "kernel-patch",
      "writes": [
        "patches/<id>.json"
      ],
      "operations": [
        "write"
      ],
      "riskDefaults": [
        "low"
      ]
    },
    {
      "kind": "file",
      "writes": [
        "any repo-tracked path"
      ],
      "operations": [
        "write",
        "delete"
      ],
      "riskDefaults": [
        "medium",
        "high"
      ]
    }
  ],
  "sessionStatuses": [
    "succeeded",
    "failed_rolled_back",
    "failed_partial"
  ],
  "phases": [
    "intake",
    "unpack",
    "manifest-validate",
    "normalize",
    "risk-classify",
    "acquire-lock",
    "policy-gates",
    "backup",
    "apply",
    "verify",
    "test",
    "finalize",
    "release-lock"
  ]
}
