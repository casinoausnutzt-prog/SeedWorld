{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SeedWorld Patch Input Schema",
  "description": "Accepted JSON input contract for the terminal-authority patch flow.",
  "oneOf": [
    {
      "$ref": "#/definitions/bundleManifest"
    },
    {
      "$ref": "#/definitions/kernelPatch"
    },
    {
      "$ref": "#/definitions/filePatch"
    }
  ],
  "definitions": {
    "bundleManifest": {
      "type": "object",
      "required": [
        "patches"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "default": "1"
        },
        "description": {
          "type": "string"
        },
        "patches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/definitions/kernelPatch"
              },
              {
                "$ref": "#/definitions/filePatch"
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "kernelPatch": {
      "type": "object",
      "required": [
        "id",
        "version",
        "description",
        "hooks"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "kernel-patch"
          ],
          "default": "kernel-patch"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string",
          "minLength": 8,
          "maxLength": 240
        },
        "author": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "hooks": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": [
              "code"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1000,
                "default": 100
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "phase": {
                "type": "string",
                "enum": [
                  "pre-update",
                  "update",
                  "post-update"
                ],
                "default": "update"
              },
              "code": {
                "type": "string",
                "minLength": 10
              }
            },
            "additionalProperties": false
          }
        },
        "schema": {
          "type": "object",
          "required": [
            "version",
            "type"
          ],
          "properties": {
            "version": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "gameplay",
                "economy",
                "ui",
                "ui-deterministic",
                "system",
                "debug"
              ]
            }
          },
          "additionalProperties": true
        },
        "rollback": {
          "type": "object"
        },
        "validation": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "filePatch": {
      "type": "object",
      "required": [
        "id",
        "path",
        "operation"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file"
          ],
          "default": "file"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "enum": [
            "write",
            "delete"
          ]
        },
        "content": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "operation": {
                "const": "write"
              }
            }
          },
          "then": {
            "required": [
              "content"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
