{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedworld.local/patches/schema.json",
  "title": "SeedWorld Patch Manifest",
  "type": "object",
  "required": ["meta", "patches"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "description", "author"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string"
        }
      }
    },
    "patches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/patch"
      }
    }
  },
  "$defs": {
    "verify": {
      "type": "object",
      "required": ["type", "file"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "contains",
            "file-exists",
            "json-field",
            "file-checksum",
            "run-command"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "expectedValue": {},
        "checksum": {
          "type": "string",
          "minLength": 8
        },
        "command": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "contains" } },
            "required": ["type"]
          },
          "then": {
            "required": ["text"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "json-field" } },
            "required": ["type"]
          },
          "then": {
            "required": ["field", "expectedValue"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "file-checksum" } },
            "required": ["type"]
          },
          "then": {
            "required": ["checksum"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "run-command" } },
            "required": ["type"]
          },
          "then": {
            "required": ["command"]
          }
        }
      ]
    },
    "patch": {
      "type": "object",
      "required": ["id", "name", "type", "file"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "string-replace",
            "file-create",
            "file-append",
            "file-replace",
            "json-update",
            "run-command"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "find": {
          "type": "string"
        },
        "replace": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "updates": {
          "type": "object"
        },
        "command": {
          "type": "string"
        },
        "stopOnError": {
          "type": "boolean"
        },
        "verify": {
          "$ref": "#/$defs/verify"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "string-replace" } },
            "required": ["type"]
          },
          "then": {
            "required": ["find", "replace"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "file-create" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "file-append" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "file-replace" } },
            "required": ["type"]
          },
          "then": {
            "required": ["content"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "json-update" } },
            "required": ["type"]
          },
          "then": {
            "required": ["updates"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "run-command" } },
            "required": ["type"]
          },
          "then": {
            "required": ["command"]
          }
        }
      ]
    }
  }
}
